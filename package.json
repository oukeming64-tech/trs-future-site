{
  "name": "trs-future-site",
  "version": "1.3.1",
  "description": "A modular, 3D-forward concept redesign for the TRS corporate website.",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "GITHUB_PAGES=true SITE_URL=https://oukeming64-tech.github.io/trs-future-site/ next build",
    "build:handoff": "SITE_URL=https://www.trs.com.cn/ next build",
    "manifest:handoff": "node scripts/write-handoff-manifest.mjs",
    "assemble:handoff": "node scripts/assemble-handoff-package.mjs",
    "package:handoff": "npm run build:handoff && npm run manifest:handoff && npm run assemble:handoff",
    "test": "npm run build:pages && node --test tests/rendered-html.test.mjs && npm run package:handoff && node --test tests/handoff-package.test.mjs",
    "lint": "eslint . --ignore-pattern out --ignore-pattern handoff-package --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.185.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "type": "module"
}
